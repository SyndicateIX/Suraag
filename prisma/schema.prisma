generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Case {
  id             String               @id @default(uuid())
  caseNumber     String               @unique
  title          String
  status         String               @default("ACTIVE") // ACTIVE, CRITICAL, ARCHIVED, PENDING_AUDIT
  priority       String               @default("HIGH")   // CRITICAL, HIGH, ROUTINE
  assignedTo     String
  location       String
  incidentDate   DateTime
  summary        String
  confidenceScore Float               @default(94.2)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  evidence       Evidence[]
  witnesses      WitnessStatement[]
  suspects       Suspect[]
  timelineEvents TimelineEvent[]
  reconstruction ReconstructionData?
}

model Evidence {
  id             String    @id @default(uuid())
  caseId         String
  case           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title          String
  category       String    // WEAPON, BLOOD, FOOTPRINT, VEHICLE, PHONE, FINGERPRINT, BALLISTICS, CCTV, DOCUMENT
  fileUrl        String
  fileType       String
  confidence     Float
  boundingBoxes  Json?     // [{ x: number, y: number, width: number, height: number, label: string, confidence: number }]
  processedStatus String   @default("COMPLETED") // PENDING, PROCESSING, COMPLETED
  metadata       Json?
  createdAt      DateTime  @default(now())
}

model WitnessStatement {
  id             String    @id @default(uuid())
  caseId         String
  case           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  witnessName    String
  role           String    @default("Primary Witness")
  statementDate  DateTime
  statementText  String
  aiExtraction   Json?     // { entities: string[], locationClaims: string[], timelineClaims: string[] }
  credibilityScore Float   @default(85.0)
  contradictions Json?     // [{ target: string, reason: string, severity: string }]
  createdAt      DateTime  @default(now())
}

model Suspect {
  id             String    @id @default(uuid())
  caseId         String
  case           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  name           String
  alias          String?
  riskScore      Int       @default(80) // 0 - 100
  probability    Float     @default(0.75)
  criminalHistory Json?    // string[]
  phone          String?
  gpsCoordinates Json?     // [{ time: string, lat: number, lng: number }]
  linkedEvidenceIds Json?  // string[]
  aiReasoning    String?
  createdAt      DateTime  @default(now())
}

model TimelineEvent {
  id                   String   @id @default(uuid())
  caseId               String
  case                 Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  timestamp            String
  title                String
  description          String
  category             String   // AUDIO, CCTV, BALLISTICS, WITNESS, VEHICLE, NETWORK
  confidence           Float    @default(90.0)
  aiReasoning          String?
  supportingEvidenceIds Json?   // string[]
  createdAt            DateTime @default(now())
}

model ReconstructionData {
  id               String   @id @default(uuid())
  caseId           String   @unique
  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  attackerPosition Json     // { x: number, y: number, z: number }
  victimPosition   Json     // { x: number, y: number, z: number }
  attackDirection  String
  weaponAngle      String
  lineOfSight      Json     // { visibilityScore: number, occludedBy: string[] }
  physicsResults   Json     // { bulletTrajectory: any, bloodSpatter: any }
  scenarios        Json     // [{ id: string, name: string, probability: number, description: string, evidenceCount: number }]
  createdAt        DateTime @default(now())
}
